# ============================================================
# iamspeaker 환경변수 예시
# 클론 후 `cp .env.example .env` 하면 로컬 모델만으로 바로 동작한다.
# [필수] 표시가 없는 항목은 모두 선택(미설정 시 로컬 폴백).
# ============================================================

# ---------- 앱 기본 ----------
NODE_ENV=development
PORT=3000
# 데이터/업로드/녹음/모델 산출물 루트 (로컬 파일시스템)
DATA_DIR=./data
# SQLite 파일 경로
DATABASE_URL=file:./data/iamspeaker.db
# 구조화 로그 레벨: trace|debug|info|warn|error
LOG_LEVEL=info

# ---------- 업로드 제한 (보안) ----------
# 허용 최대 업로드 크기 (MB)
MAX_UPLOAD_MB=50
# 허용 확장자 (쉼표 구분)
ALLOWED_UPLOAD_EXT=pptx,pdf

# ---------- 로컬 AI 모델 (기본 엔진) ----------
# Ollama (Script/Q&A/Slide-Critic LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Piper TTS — voice 모델 경로 (scripts/setup-models.ts로 다운로드)
PIPER_BIN=piper
PIPER_VOICE_DIR=./data/models/piper
PIPER_DEFAULT_VOICE=en_US-amy-medium
# 데모에서 남성 목소리 선택 시 사용할 voice (female=PIPER_DEFAULT_VOICE, male=아래)
PIPER_MALE_VOICE=en_US-joe-medium

# Whisper.cpp STT — word-level timestamp 필수
WHISPER_BIN=whisper-cli
WHISPER_MODEL_PATH=./data/models/whisper/ggml-base.en.bin

# ffmpeg (오디오 정규화: 16kHz mono WAV)
FFMPEG_BIN=ffmpeg

# 발음 평가: heuristic(기본, 의존성 0) | wav2vec2(옵션 GOP, scripts/pronunciation/requirements.txt 설치 필요)
PRONUNCIATION_SCORER=heuristic
PYTHON_BIN=python3
WAV2VEC2_PHONEME_MODEL=facebook/wav2vec2-lv-60-espeak-cv-ft
WAV2VEC2_GOP_THRESHOLD=0.5

# ---------- 선택적 클라우드 어댑터 (설정 시 우선 사용) ----------
# Script Generator / Q&A / Slide Critic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# TTS
ELEVENLABS_API_KEY=
# STT (OpenAI Whisper API / Azure Speech)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ---------- 작업 워커 ----------
# 동시에 처리할 추론 작업 수 (로컬 모델 자원 한계 고려)
JOB_CONCURRENCY=1
# 작업 타임아웃 (초)
JOB_TIMEOUT_SEC=600
# 실패 시 최대 시도 횟수 (1=무재시도). 초과 시 dead-letter(terminal failed)로 보존
JOB_MAX_ATTEMPTS=3
# 재시도 백오프 기준 (ms). 지연 = base × 2^(시도-1)
JOB_RETRY_BASE_MS=1000
# 완료(succeeded) 작업 TTL (시간). 경과분은 주기적으로 삭제. 실패 작업은 점검 위해 보존
JOB_TTL_HOURS=24

# ---------- 레이트리밋 ----------
# 인프로세스 고정창 리미터(라우트·IP별). 폭주/남용 방어. "0"|"false"면 비활성
RATE_LIMIT_ENABLED=true
# 창(window)당 허용 요청 수
RATE_LIMIT_MAX=30
# 창 길이 (초)
RATE_LIMIT_WINDOW_SEC=60

# ---------- 테스트 전용 ----------
# "1"이면 모든 AI 어댑터를 stub으로 강제(모델 없이 결정적 동작). E2E/CI에서 사용. 운영에선 설정하지 말 것.
USE_STUB_ADAPTERS=
