{
  "name": "iamspeaker",
  "version": "0.2.2",
  "private": true,
  "description": "오픈소스 발표 연습 웹앱 — 슬라이드 업로드 → AI 시범 발표 → 연습 녹음 분석(속도·발음·필러) → 개선 스크립트·Q&A. 로컬 모델 우선.",
  "license": "MIT",
  "author": "Seung Park",
  "repository": { "type": "git", "url": "https://github.com/spark798/iamspeaker.git" },
  "homepage": "https://github.com/spark798/iamspeaker#readme",
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "setup:models": "tsx scripts/setup-models.ts",
    "preflight": "tsx scripts/preflight.ts",
    "eval": "tsx scripts/eval.ts",
    "eval:accuracy": "tsx scripts/eval-accuracy.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.3",
    "next": "^15.1.0",
    "next-intl": "^4.13.0",
    "pino": "^9.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "unpdf": "^1.6.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^25.0.0",
    "pdf-lib": "^1.17.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
